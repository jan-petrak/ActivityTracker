<UserControl x:Class="ActivityTracker.Views.ActivitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="32">
        <TextBlock Text="Activities" Style="{StaticResource SectionHeader}" DockPanel.Dock="Top"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Groups & Activities -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="+ Group" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"
                                Command="{Binding AddGroupCommand}"/>
                        <Button Content="+ Activity" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding AddActivityCommand}"
                                IsEnabled="{Binding SelectedGroup, Converter={StaticResource NotNullToBoolConverter}}"/>
                    </StackPanel>

                    <TreeView ItemsSource="{Binding Groups}"
                              SelectedItemChanged="TreeView_SelectedItemChanged"
                              BorderThickness="0" Background="Transparent"
                              Foreground="{StaticResource TextPrimary}">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type local:ActivityGroup}"
                                                      ItemsSource="{Binding Activities}"
                                                      xmlns:local="clr-namespace:ActivityTracker.Models">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="12" Height="12" CornerRadius="4" Margin="0,0,10,0"
                                            Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13.5"
                                               Foreground="{StaticResource TextPrimary}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                            <DataTemplate DataType="{x:Type local:Activity}"
                                          xmlns:local="clr-namespace:ActivityTracker.Models">
                                <TextBlock Text="{Binding Name}" FontSize="12.5" Margin="4,3"
                                           Foreground="{StaticResource TextSecondary}"/>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Right: Detail panel -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <!-- Activity actions (shown when an activity is selected) -->
                            <Button Content="Edit Activity" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"
                                    Command="{Binding EditActivityCommand}"
                                    Visibility="{Binding SelectedActivity, Converter={StaticResource NotNullToVisibleConverter}, FallbackValue=Collapsed}"/>
                            <Button Content="Delete Activity" Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding DeleteActivityCommand}"
                                    Visibility="{Binding SelectedActivity, Converter={StaticResource NotNullToVisibleConverter}, FallbackValue=Collapsed}"/>
                            <!-- Group actions (shown only when a group is selected and no activity under it is selected) -->
                            <Button Content="Edit Group" Margin="0,0,6,0"
                                    Command="{Binding EditGroupCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding SelectedGroup, Converter={StaticResource NotNullToBoolConverter}}" Value="True"/>
                                                    <Condition Binding="{Binding SelectedActivity, Converter={StaticResource NotNullToBoolConverter}}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Delete Group"
                                    Command="{Binding DeleteGroupCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding SelectedGroup, Converter={StaticResource NotNullToBoolConverter}}" Value="True"/>
                                                    <Condition Binding="{Binding SelectedActivity, Converter={StaticResource NotNullToBoolConverter}}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextPrimary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Select a group or activity"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedActivity, Converter={StaticResource NotNullToBoolConverter}}" Value="True">
                                            <Setter Property="Text" Value="{Binding SelectedActivity.Name}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DockPanel>

                    <StackPanel Visibility="{Binding SelectedActivity, Converter={StaticResource NotNullToVisibleConverter}, FallbackValue=Collapsed}"
                                Orientation="Horizontal">
                        <Button Content="+ Plan Session" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding AddPlannedEntryCommand}"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
