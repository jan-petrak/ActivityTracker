<UserControl x:Class="ActivityTracker.Views.ActivitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="24">
        <TextBlock Text="Activities" Style="{StaticResource SectionHeader}" DockPanel.Dock="Top"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Groups & Activities tree -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="+ Group" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding AddGroupCommand}" Margin="0,0,8,0"/>
                        <Button Content="+ Activity" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding AddActivityCommand}"
                                IsEnabled="{Binding SelectedGroup, Converter={StaticResource NotNullToBoolConverter}}"/>
                    </StackPanel>

                    <TreeView ItemsSource="{Binding Groups}"
                              SelectedItemChanged="TreeView_SelectedItemChanged"
                              BorderThickness="0" Background="Transparent">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type local:ActivityGroup}"
                                                      ItemsSource="{Binding Activities}"
                                                      xmlns:local="clr-namespace:ActivityTracker.Models">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="12" Height="12" CornerRadius="3" Margin="0,0,8,0"
                                            Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                            <DataTemplate DataType="{x:Type local:Activity}"
                                          xmlns:local="clr-namespace:ActivityTracker.Models">
                                <TextBlock Text="{Binding Name}" FontSize="12" Margin="4,2"/>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Right: Detail panel -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <DockPanel>
                    <!-- Header with actions -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="Edit" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding EditGroupCommand}" Margin="0,0,4,0"
                                    Visibility="{Binding SelectedGroup, Converter={StaticResource NotNullToVisibleConverter}, FallbackValue=Collapsed}"/>
                            <Button Content="Delete" Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding DeleteGroupCommand}"
                                    Visibility="{Binding SelectedGroup, Converter={StaticResource NotNullToVisibleConverter}, FallbackValue=Collapsed}"/>
                        </StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Select a group or activity"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedActivity, Converter={StaticResource NotNullToBoolConverter}}" Value="True">
                                            <Setter Property="Text" Value="{Binding SelectedActivity.Name}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DockPanel>

                    <!-- Time entries for selected activity -->
                    <DockPanel Visibility="{Binding SelectedActivity, Converter={StaticResource NotNullToVisibleConverter}, FallbackValue=Collapsed}">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="+ Log Time" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding AddTimeEntryCommand}" Margin="0,0,8,0"/>
                            <Button Content="+ Plan Session" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding AddPlannedEntryCommand}"/>
                        </StackPanel>

                        <ListView ItemsSource="{Binding SelectedActivityEntries}" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Date" Width="100"
                                                    DisplayMemberBinding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}"/>
                                    <GridViewColumn Header="Start" Width="70"
                                                    DisplayMemberBinding="{Binding StartTime, StringFormat='{}{0:HH:mm}'}"/>
                                    <GridViewColumn Header="End" Width="70"
                                                    DisplayMemberBinding="{Binding EndTime, StringFormat='{}{0:HH:mm}'}"/>
                                    <GridViewColumn Header="Duration" Width="80">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0:0.#}h">
                                                            <Binding Path="EndTime"/>
                                                            <Binding Path="StartTime"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Notes" Width="200"
                                                    DisplayMemberBinding="{Binding Notes}"/>
                                    <GridViewColumn Header="" Width="120">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Edit" FontSize="11" Padding="8,3"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding DataContext.EditTimeEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" Margin="0,0,4,0"/>
                                                    <Button Content="Del" FontSize="11" Padding="8,3"
                                                            Style="{StaticResource DangerButtonStyle}"
                                                            Command="{Binding DataContext.DeleteTimeEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
