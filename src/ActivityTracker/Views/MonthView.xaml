<UserControl x:Class="ActivityTracker.Views.MonthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <TextBlock Text="{Binding MonthHeader}" FontSize="16" FontWeight="SemiBold"
                   Foreground="#333" DockPanel.Dock="Top" Margin="0,0,0,8"/>

        <!-- Day of week headers -->
        <UniformGrid Rows="1" Columns="7" DockPanel.Dock="Top">
            <TextBlock Text="Mon" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#666" Margin="0,4"/>
            <TextBlock Text="Tue" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#666" Margin="0,4"/>
            <TextBlock Text="Wed" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#666" Margin="0,4"/>
            <TextBlock Text="Thu" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#666" Margin="0,4"/>
            <TextBlock Text="Fri" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#666" Margin="0,4"/>
            <TextBlock Text="Sat" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#999" Margin="0,4"/>
            <TextBlock Text="Sun" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#999" Margin="0,4"/>
        </UniformGrid>

        <!-- Month grid -->
        <ItemsControl ItemsSource="{Binding DayCells}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="6" Columns="7"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#E0E0E0" BorderThickness="0.5" Padding="4" MinHeight="90">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                        <Setter Property="Background" Value="#FAFAFA"/>
                                        <Setter Property="Opacity" Value="0.6"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                        <Setter Property="Background" Value="#E8F0FE"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding DayNumber}" FontWeight="SemiBold" FontSize="13"
                                       Margin="0,0,0,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#333"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                <Setter Property="Foreground" Value="#0078D4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Entry snippets -->
                            <ItemsControl ItemsSource="{Binding Entries}" MaxHeight="60">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Summary}" FontSize="9"
                                                   TextTrimming="CharacterEllipsis" Margin="0,1">
                                            <TextBlock.Foreground>
                                                <Binding Path="Color" Converter="{StaticResource StringToBrushConverter}"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock FontSize="9" Foreground="#999" Margin="0,2,0,0"
                                       Visibility="{Binding TotalHours, Converter={StaticResource NonZeroToVisibleConverter}, FallbackValue=Collapsed}">
                                <Run Text="{Binding TotalHours, StringFormat='{}{0:0.#}h'}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
