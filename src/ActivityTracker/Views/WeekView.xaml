<UserControl x:Class="ActivityTracker.Views.WeekView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ActivityTracker.Views">
    <UserControl.Resources>
        <Geometry x:Key="DayEventIconGeometry">M 0,0 L 7,0 L 5,3 L 7,6 L 0,6 Z M 0,0 L 0,10</Geometry>
    </UserControl.Resources>
    <Grid x:Name="WeekRoot">
    <DockPanel>
        <TextBlock Text="{Binding WeekHeader}" FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimary}" DockPanel.Dock="Top" Margin="0,0,0,10"/>

        <!-- Non-scrolling header + all-day area -->
        <Grid DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="17"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Day headers -->
            <ItemsControl Grid.Column="1" Grid.Row="0" ItemsSource="{Binding Days}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="4,8" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,1"
                                Tag="{Binding Date}"
                                MouseRightButtonUp="DayHeader_MouseRightButtonUp">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Add whole-day event" Click="AddDayEvent_Click"
                                              Tag="{Binding Date}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentAmberSubtle}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding Header}" FontWeight="SemiBold" FontSize="12"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentAmber}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- All-day rows per column -->
            <ItemsControl Grid.Column="1" Grid.Row="1" ItemsSource="{Binding Days}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,1"
                                Padding="2,4" MinHeight="30" Tag="{Binding Date}"
                                MouseRightButtonUp="DayHeader_MouseRightButtonUp">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Add whole-day event" Click="AddDayEvent_Click"
                                              Tag="{Binding Date}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="90"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding DayEvents}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,1" Padding="4,2" CornerRadius="3"
                                                    Background="{StaticResource BgHover}"
                                                    BorderBrush="{StaticResource BorderMedium}" BorderThickness="1"
                                                    Cursor="Hand" Tag="{Binding SourceId}"
                                                    MouseLeftButtonUp="DayEventPill_Click">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Edit" Click="DayEventPill_Edit_Click"
                                                                  Tag="{Binding SourceId}"/>
                                                        <MenuItem Header="Delete" Click="DayEventPill_Delete_Click"
                                                                  Tag="{Binding SourceId}"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <DockPanel>
                                                    <Path DockPanel.Dock="Left" Data="{StaticResource DayEventIconGeometry}"
                                                          Stroke="{StaticResource AccentAmber}" StrokeThickness="1.2"
                                                          Fill="{StaticResource AccentAmber}"
                                                          Width="8" Height="10" Stretch="Uniform"
                                                          VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled"
                      Loaded="ScrollViewer_Loaded">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Time gutter -->
                <ItemsControl Grid.Column="0" ItemsSource="{x:Static views:DayView.Hours}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><Canvas Height="1440"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextMuted}" FontSize="10.5"
                                       Width="50" TextAlignment="Right" Margin="0,0,8,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Day columns with entries + drag -->
                <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0"
                                    Tag="{Binding Date}">
                                <Grid>
                                    <Canvas Height="1440" ClipToBounds="True">
                                        <ItemsControl ItemsSource="{x:Static views:DayView.Hours}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><Canvas Height="1440"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Line X1="0" X2="500" Stroke="#1A1E30" StrokeThickness="1"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <ItemsControl ItemsSource="{Binding Entries}" Loaded="WeekEntries_Loaded">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><Canvas Height="1440"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="4" Padding="4,2" Margin="2,0"
                                                            Tag="{Binding SourceId}"
                                                            MouseLeftButtonDown="EntryBlock_MouseLeftButtonDown"
                                                            MouseMove="EntryBlock_MouseMove"
                                                            MouseLeftButtonUp="EntryBlock_MouseLeftButtonUp">
                                                        <Border.Background>
                                                            <Binding Path="Color" Converter="{StaticResource StringToBrushConverter}"/>
                                                        </Border.Background>
                                                        <Border.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="Edit" Click="EntryBlock_Edit_Click"
                                                                          Tag="{Binding SourceId}"/>
                                                                <MenuItem Header="Delete" Click="EntryBlock_Delete_Click"
                                                                          Tag="{Binding SourceId}"/>
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <TextBlock Foreground="White" FontSize="10"
                                                                   TextTrimming="CharacterEllipsis" TextWrapping="Wrap">
                                                            <Run Text="{Binding ActivityName}" FontWeight="SemiBold"/>
                                                            <LineBreak/>
                                                            <Run Text="{Binding StartTime, StringFormat='{}{0:HH:mm}'}"/>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>

                                    <Canvas Height="1440" Background="Transparent"
                                            Tag="{Binding Date}"
                                            MouseLeftButtonDown="WeekDragCanvas_MouseLeftButtonDown"
                                            MouseMove="WeekDragCanvas_MouseMove"
                                            MouseLeftButtonUp="WeekDragCanvas_MouseLeftButtonUp"
                                            Panel.ZIndex="-1">
                                        <Canvas.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Add whole-day event" Click="AddDayEvent_Click"
                                                          Tag="{Binding Date}"/>
                                            </ContextMenu>
                                        </Canvas.ContextMenu>
                                    </Canvas>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </DockPanel>
        <Canvas x:Name="DragGhostLayer" IsHitTestVisible="False">
            <Border x:Name="DragGhost" Visibility="Collapsed"
                    Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource AccentAmber}" BorderThickness="1"
                    CornerRadius="4" Padding="6,3" Opacity="0.92">
                <TextBlock x:Name="DragGhostText" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"
                           TextTrimming="CharacterEllipsis" MaxWidth="240"/>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
