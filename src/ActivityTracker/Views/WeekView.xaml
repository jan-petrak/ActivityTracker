<UserControl x:Class="ActivityTracker.Views.WeekView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ActivityTracker.Views">
    <DockPanel>
        <TextBlock Text="{Binding WeekHeader}" FontSize="16" FontWeight="SemiBold"
                   Foreground="#333" DockPanel.Dock="Top" Margin="0,0,0,8"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Loaded="ScrollViewer_Loaded">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Time gutter -->
                <ItemsControl Grid.Column="0" ItemsSource="{x:Static views:DayView.Hours}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Height="1440"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" Foreground="#999" FontSize="11"
                                       Width="50" TextAlignment="Right" Margin="0,0,8,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Day columns -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Day headers -->
                    <ItemsControl Grid.Row="0" ItemsSource="{Binding Days}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,6" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                    <Setter Property="Background" Value="#E8F0FE"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Header}" FontWeight="SemiBold" FontSize="12"
                                               HorizontalAlignment="Center" Foreground="#444"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Day columns with entries -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Days}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E8E8E8" BorderThickness="0,0,1,0">
                                    <Canvas Height="1440" x:Name="DayCanvas" ClipToBounds="True">
                                        <!-- Hour lines -->
                                        <ItemsControl ItemsSource="{x:Static views:DayView.Hours}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas Height="1440"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Line X1="0" X2="500" Stroke="#F0F0F0" StrokeThickness="1"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Entry blocks rendered in code-behind -->
                                        <ItemsControl ItemsSource="{Binding Entries}" x:Name="WeekEntries"
                                                      Loaded="WeekEntries_Loaded">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas Height="1440"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="3" Padding="4,2" Margin="2,0"
                                                            Width="Auto" HorizontalAlignment="Stretch">
                                                        <Border.Background>
                                                            <Binding Path="Color" Converter="{StaticResource StringToBrushConverter}"/>
                                                        </Border.Background>
                                                        <TextBlock Foreground="White" FontSize="10"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="Wrap">
                                                            <Run Text="{Binding ActivityName}" FontWeight="SemiBold"/>
                                                            <LineBreak/>
                                                            <Run Text="{Binding StartTime, StringFormat='{}{0:HH:mm}'}"/>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</UserControl>
