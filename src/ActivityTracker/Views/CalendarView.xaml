<UserControl x:Class="ActivityTracker.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ActivityTracker.ViewModels"
             xmlns:views="clr-namespace:ActivityTracker.Views">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:DayViewModel}">
            <views:DayView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WeekViewModel}">
            <views:WeekView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MonthViewModel}">
            <views:MonthView/>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel Margin="32">
        <TextBlock Text="Calendar" Style="{StaticResource SectionHeader}" DockPanel.Dock="Top"/>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,20">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <RadioButton Content="Day" GroupName="CalView"
                                 IsChecked="{Binding ViewMode, Converter={StaticResource StringMatchConverter}, ConverterParameter=Day, Mode=OneWay}"
                                 Command="{Binding SwitchViewCommand}" CommandParameter="Day"
                                 Style="{StaticResource ViewModeButtonStyle}"/>
                    <RadioButton Content="Week" GroupName="CalView"
                                 IsChecked="{Binding ViewMode, Converter={StaticResource StringMatchConverter}, ConverterParameter=Week, Mode=OneWay}"
                                 Command="{Binding SwitchViewCommand}" CommandParameter="Week"
                                 Style="{StaticResource ViewModeButtonStyle}"/>
                    <RadioButton Content="Month" GroupName="CalView"
                                 IsChecked="{Binding ViewMode, Converter={StaticResource StringMatchConverter}, ConverterParameter=Month, Mode=OneWay}"
                                 Command="{Binding SwitchViewCommand}" CommandParameter="Month"
                                 Style="{StaticResource ViewModeButtonStyle}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Button Content="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                            Command="{Binding NavigateBackCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="10,8"/>
                    <Button Content="Today"
                            Command="{Binding GoToTodayCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="4,0"/>
                    <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                            Command="{Binding NavigateForwardCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="10,8"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ContentControl Content="{Binding ActiveCalendarView}"/>
    </DockPanel>
</UserControl>
