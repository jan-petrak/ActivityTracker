<UserControl x:Class="ActivityTracker.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Statistics" Style="{StaticResource SectionHeader}"/>

            <!-- Period selector -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="TIME PERIOD" Style="{StaticResource CardHeader}"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Last 7 days" GroupName="StatPeriod" Margin="0,0,16,0"
                                     IsChecked="{Binding PeriodSelection, Converter={StaticResource StringMatchConverter}, ConverterParameter=LastWeek, Mode=OneWay}"
                                     Command="{Binding SelectPeriodCommand}" CommandParameter="LastWeek"/>
                        <RadioButton Content="Last 30 days" GroupName="StatPeriod" Margin="0,0,16,0"
                                     IsChecked="{Binding PeriodSelection, Converter={StaticResource StringMatchConverter}, ConverterParameter=LastMonth, Mode=OneWay}"
                                     Command="{Binding SelectPeriodCommand}" CommandParameter="LastMonth"/>
                        <RadioButton Content="Last 90 days" GroupName="StatPeriod"
                                     IsChecked="{Binding PeriodSelection, Converter={StaticResource StringMatchConverter}, ConverterParameter=Last3Months, Mode=OneWay}"
                                     Command="{Binding SelectPeriodCommand}" CommandParameter="Last3Months"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Summary -->
            <WrapPanel>
                <Border Style="{StaticResource CardStyle}" Width="200">
                    <StackPanel>
                        <TextBlock Text="TOTAL HOURS" Style="{StaticResource CardHeader}"/>
                        <TextBlock FontSize="32" FontWeight="Light" Foreground="#0078D4">
                            <Run Text="{Binding TotalHours, StringFormat='{}{0:0.#}'}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Width="200">
                    <StackPanel>
                        <TextBlock Text="SESSIONS" Style="{StaticResource CardHeader}"/>
                        <TextBlock FontSize="32" FontWeight="Light" Foreground="#0078D4"
                                   Text="{Binding TotalSessions}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Group breakdown -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="BY GROUP" Style="{StaticResource CardHeader}"/>
                    <ItemsControl ItemsSource="{Binding GroupSummaries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,6">
                                    <StackPanel DockPanel.Dock="Right" Width="180" Margin="12,0,0,0">
                                        <TextBlock FontSize="12" Foreground="#666">
                                            <Run Text="{Binding TotalHours, StringFormat='{}{0:0.#}h'}"/>
                                            <Run Text=" total"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="#999">
                                            <Run Text="{Binding DailyAverage, StringFormat='{}{0:0.##}h/day'}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding ActiveDays}"/>
                                            <Run Text=" days · "/>
                                            <Run Text="{Binding CurrentStreak}"/>
                                            <Run Text=" streak"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <DockPanel>
                                        <TextBlock Text="{Binding GroupName}" DockPanel.Dock="Top"
                                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                        <Border Height="20" CornerRadius="4" HorizontalAlignment="Left">
                                            <Border.Background>
                                                <Binding Path="Color" Converter="{StaticResource StringToBrushConverter}"/>
                                            </Border.Background>
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource HoursToWidthConverter}">
                                                    <Binding Path="TotalHours"/>
                                                    <Binding Path="DataContext.GroupSummaries"
                                                             RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </DockPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Goals -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <Button Content="+ Add Goal" Style="{StaticResource PrimaryButtonStyle}"
                                DockPanel.Dock="Right" Command="{Binding AddGoalCommand}"/>
                        <TextBlock Text="GOAL PROGRESS" Style="{StaticResource CardHeader}"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding GoalProgress}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4,0,8">
                                    <DockPanel>
                                        <TextBlock Text="{Binding Label}" FontSize="13"/>
                                        <TextBlock DockPanel.Dock="Right" FontSize="12" Foreground="#666">
                                            <Run Text="{Binding ActualHours, StringFormat='{}{0:0.#}'}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{Binding TargetHours, StringFormat='{}{0:0.#}h'}"/>
                                            <Run Text=" ("/>
                                            <Run Text="{Binding ProgressPercentage, StringFormat='{}{0:0}%'}"/>
                                            <Run Text=")"/>
                                        </TextBlock>
                                    </DockPanel>
                                    <Border Height="10" CornerRadius="5" Background="#E8E8E8" Margin="0,4,0,0">
                                        <Border Height="10" CornerRadius="5" HorizontalAlignment="Left"
                                                Width="{Binding ProgressPercentage, Converter={StaticResource PercentToWidthConverter}, ConverterParameter=500}">
                                            <Border.Background>
                                                <Binding Path="Color" Converter="{StaticResource StringToBrushConverter}"/>
                                            </Border.Background>
                                        </Border>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Hour distribution -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="TIME OF DAY DISTRIBUTION" Style="{StaticResource CardHeader}"/>
                    <ItemsControl ItemsSource="{Binding HourDistribution}" Height="120">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <TextBlock Text="{Binding Hour}" FontSize="8" Foreground="#999"
                                               HorizontalAlignment="Center" DockPanel.Dock="Bottom"/>
                                    <Border VerticalAlignment="Bottom" Margin="1,0" CornerRadius="2,2,0,0"
                                            Background="#0078D4"
                                            Height="{Binding TotalMinutes, Converter={StaticResource MinutesToBarHeightConverter}}"
                                            ToolTip="{Binding TotalMinutes, StringFormat='{}{0:0} min'}"/>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
