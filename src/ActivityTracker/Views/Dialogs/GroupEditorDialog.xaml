<Window x:Class="ActivityTracker.Views.Dialogs.GroupEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activity Group" Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBase}">
    <Window.Resources>
        <Style x:Key="ColorSwatchStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Width="36" Height="36" CornerRadius="8" Margin="4"
                                Cursor="Hand" BorderThickness="3" BorderBrush="Transparent"
                                Background="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource StringToBrushConverter}}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentAmber}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="28">
        <TextBlock Text="Group Name" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{StaticResource TextSecondary}" FontSize="12"/>
        <TextBox x:Name="NameBox" Style="{StaticResource DarkTextBoxStyle}"/>

        <TextBlock Text="Color" FontWeight="SemiBold" Margin="0,20,0,8"
                   Foreground="{StaticResource TextSecondary}" FontSize="12"/>
        <WrapPanel x:Name="ColorPanel">
            <RadioButton Tag="#4A90D9" Style="{StaticResource ColorSwatchStyle}" IsChecked="True"/>
            <RadioButton Tag="#50C878" Style="{StaticResource ColorSwatchStyle}"/>
            <RadioButton Tag="#FF6B6B" Style="{StaticResource ColorSwatchStyle}"/>
            <RadioButton Tag="#FFB347" Style="{StaticResource ColorSwatchStyle}"/>
            <RadioButton Tag="#9B59B6" Style="{StaticResource ColorSwatchStyle}"/>
            <RadioButton Tag="#1ABC9C" Style="{StaticResource ColorSwatchStyle}"/>
            <RadioButton Tag="#E74C3C" Style="{StaticResource ColorSwatchStyle}"/>
            <RadioButton Tag="#3498DB" Style="{StaticResource ColorSwatchStyle}"/>
            <RadioButton Tag="#F39C12" Style="{StaticResource ColorSwatchStyle}"/>
            <RadioButton Tag="#2ECC71" Style="{StaticResource ColorSwatchStyle}"/>
        </WrapPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,28,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}"
                    Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}"
                    Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
