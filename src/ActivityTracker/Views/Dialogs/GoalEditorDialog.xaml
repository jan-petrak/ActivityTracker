<Window x:Class="ActivityTracker.Views.Dialogs.GoalEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Goal" Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource DialogWindowStyle}">
    <StackPanel Margin="28">
        <TextBlock Text="Group" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{StaticResource TextSecondary}" FontSize="12"/>
        <ComboBox x:Name="GroupCombo" DisplayMemberPath="Name" SelectedValuePath="Id"
                  SelectionChanged="GroupCombo_SelectionChanged"/>

        <TextBlock Text="Activity (optional — leave empty for whole group)" FontWeight="SemiBold" Margin="0,18,0,8"
                   Foreground="{StaticResource TextSecondary}" FontSize="12"/>
        <ComboBox x:Name="ActivityCombo" DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <TextBlock Text="Period" FontWeight="SemiBold" Margin="0,18,0,8"
                   Foreground="{StaticResource TextSecondary}" FontSize="12"/>
        <ComboBox x:Name="PeriodCombo" SelectedIndex="0">
            <ComboBoxItem Content="Weekly"/>
            <ComboBoxItem Content="Monthly"/>
        </ComboBox>

        <TextBlock Text="Target Hours" FontWeight="SemiBold" Margin="0,18,0,8"
                   Foreground="{StaticResource TextSecondary}" FontSize="12"/>
        <TextBox x:Name="TargetBox" Style="{StaticResource DarkTextBoxStyle}" Text="10"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,28,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}"
                    Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}"
                    Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
