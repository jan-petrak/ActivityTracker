<Window x:Class="ActivityTracker.Views.Dialogs.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource DialogWindowStyle}">
    <StackPanel Margin="28,20,28,24">
        <TextBlock x:Name="MessageText" FontSize="13"
                   Foreground="{StaticResource TextPrimary}"
                   TextWrapping="Wrap" LineHeight="20"/>
        <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button x:Name="SecondaryButton" Style="{StaticResource SecondaryButtonStyle}"
                    Click="Secondary_Click" Margin="0,0,8,0" Visibility="Collapsed"/>
            <Button x:Name="PrimaryButton" Style="{StaticResource PrimaryButtonStyle}"
                    Click="Primary_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
