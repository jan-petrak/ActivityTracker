<Window x:Class="ActivityTracker.Views.Dialogs.RecurrencePromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recurring entry" Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource DialogWindowStyle}">
    <StackPanel Margin="28,20,28,24">
        <TextBlock x:Name="MessageText" FontSize="13"
                   Foreground="{StaticResource TextPrimary}"
                   TextWrapping="Wrap" LineHeight="20"/>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}"
                    Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Whole series" Style="{StaticResource SecondaryButtonStyle}"
                    Click="WholeSeries_Click" Margin="0,0,8,0"/>
            <Button Content="This occurrence" Style="{StaticResource PrimaryButtonStyle}"
                    Click="ThisOccurrence_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
