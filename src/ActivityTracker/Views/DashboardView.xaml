<UserControl x:Class="ActivityTracker.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ActivityTracker.ViewModels">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel Margin="24">
            <TextBlock Text="Dashboard" Style="{StaticResource SectionHeader}"/>

            <WrapPanel>
                <!-- Today's Schedule Card -->
                <Border Style="{StaticResource CardStyle}" Width="360">
                    <StackPanel>
                        <TextBlock Text="TODAY'S SCHEDULE" Style="{StaticResource CardHeader}"/>
                        <ItemsControl ItemsSource="{Binding TodaySchedule}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2" Padding="8,6" CornerRadius="4"
                                            Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"
                                            Opacity="0.85">
                                        <DockPanel>
                                            <Border Width="4" CornerRadius="2" Margin="0,0,8,0"
                                                    DockPanel.Dock="Left"
                                                    Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"/>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" FontSize="13">
                                                    <Run Text="{Binding StartTime, StringFormat='{}{0:HH:mm}'}"/>
                                                    <Run Text=" – "/>
                                                    <Run Text="{Binding EndTime, StringFormat='{}{0:HH:mm}'}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Summary}" FontSize="12" Foreground="#555"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No activities scheduled for today"
                                   Visibility="{Binding TodaySchedule.Count, Converter={StaticResource ZeroToVisibleConverter}, FallbackValue=Collapsed}"
                                   Foreground="#999" FontStyle="Italic" Margin="0,8"/>
                    </StackPanel>
                </Border>

                <!-- Weekly Hours Card -->
                <Border Style="{StaticResource CardStyle}" Width="360">
                    <StackPanel>
                        <TextBlock Text="THIS WEEK" Style="{StaticResource CardHeader}"/>
                        <TextBlock FontSize="36" FontWeight="Light" Foreground="#0078D4">
                            <Run Text="{Binding WeeklyHoursLogged, StringFormat='{}{0:0.#}'}"/>
                            <Run Text="h" FontSize="18" Foreground="#999"/>
                        </TextBlock>
                        <TextBlock Text="hours logged" Foreground="#999" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding WeeklyGroupSummaries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,3">
                                        <TextBlock Text="{Binding TotalHours, StringFormat='{}{0:0.#}h'}"
                                                   DockPanel.Dock="Right" Foreground="#666" Width="40" TextAlignment="Right"/>
                                        <Border Height="18" CornerRadius="3" Margin="0,0,8,0"
                                                Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}">
                                            <TextBlock Text="{Binding GroupName}" Foreground="White" FontSize="11"
                                                       Margin="6,0" VerticalAlignment="Center"/>
                                        </Border>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Goals Card -->
                <Border Style="{StaticResource CardStyle}" Width="360">
                    <StackPanel>
                        <TextBlock Text="ACTIVE GOALS" Style="{StaticResource CardHeader}"/>
                        <ItemsControl ItemsSource="{Binding ActiveGoals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4">
                                        <DockPanel>
                                            <TextBlock Text="{Binding Label}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock DockPanel.Dock="Right" FontSize="12" Foreground="#666">
                                                <Run Text="{Binding ActualHours, StringFormat='{}{0:0.#}'}"/>
                                                <Run Text="/"/>
                                                <Run Text="{Binding TargetHours, StringFormat='{}{0:0.#}h'}"/>
                                            </TextBlock>
                                        </DockPanel>
                                        <Border Height="8" CornerRadius="4" Background="#E8E8E8" Margin="0,4,0,0">
                                            <Border Height="8" CornerRadius="4" HorizontalAlignment="Left"
                                                    Width="{Binding ProgressPercentage, Converter={StaticResource PercentToWidthConverter}, ConverterParameter=320}"
                                                    Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"/>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No active goals — set them in Statistics"
                                   Visibility="{Binding ActiveGoals.Count, Converter={StaticResource ZeroToVisibleConverter}, FallbackValue=Collapsed}"
                                   Foreground="#999" FontStyle="Italic" Margin="0,8"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
