<UserControl x:Class="ActivityTracker.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Small pin/flag glyph for whole-day events -->
        <Geometry x:Key="DayEventIconGeometry">M 0,0 L 7,0 L 5,3 L 7,6 L 0,6 Z M 0,0 L 0,10</Geometry>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">
            <TextBlock Text="Dashboard" Style="{StaticResource SectionHeader}"/>

            <WrapPanel>
                <!-- Today's Schedule -->
                <Border Style="{StaticResource CardStyle}" Width="380">
                    <StackPanel>
                        <TextBlock Text="TODAY'S SCHEDULE" Style="{StaticResource CardHeader}"/>

                        <!-- Whole-day events -->
                        <ItemsControl ItemsSource="{Binding TodayDayEvents}" Tag="today">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" Padding="10,8" CornerRadius="8"
                                            Background="{StaticResource BgHover}"
                                            BorderBrush="{StaticResource BorderMedium}" BorderThickness="1"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="DayEventRow_MouseLeftButtonUp"
                                            Tag="{Binding SourceId}">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Edit" Click="DayEventEdit_Click"
                                                          Tag="{Binding SourceId}"/>
                                                <MenuItem Header="Delete" Click="DayEventDelete_Click"
                                                          Tag="{Binding SourceId}"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <DockPanel>
                                            <Path DockPanel.Dock="Left" Data="{StaticResource DayEventIconGeometry}"
                                                  Stroke="{StaticResource AccentAmber}" StrokeThickness="1.2"
                                                  Fill="{StaticResource AccentAmber}"
                                                  Width="9" Height="11" Stretch="Uniform"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Separator between whole-day and timed (visible only when both non-empty) -->
                        <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="0,6,0,6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding TodayDayEvents.Count, Converter={StaticResource NonZeroToVisibleConverter}}" Value="Visible"/>
                                                <Condition Binding="{Binding TodaySchedule.Count, Converter={StaticResource NonZeroToVisibleConverter}}" Value="Visible"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <!-- Timed entries -->
                        <ItemsControl ItemsSource="{Binding TodaySchedule}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" Padding="10,8" CornerRadius="8"
                                            Background="{StaticResource BgSurface}"
                                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
                                        <DockPanel>
                                            <Border Width="4" CornerRadius="2" Margin="0,0,10,0"
                                                    DockPanel.Dock="Left"
                                                    Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"/>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{StaticResource TextPrimary}">
                                                    <Run Text="{Binding StartTime, StringFormat='{}{0:HH:mm}'}"/>
                                                    <Run Text=" – " Foreground="{StaticResource TextMuted}"/>
                                                    <Run Text="{Binding EndTime, StringFormat='{}{0:HH:mm}'}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Summary}" FontSize="12"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="No activities scheduled for today"
                                   Foreground="{StaticResource TextMuted}" FontStyle="Italic" Margin="0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding TodayDayEvents.Count}" Value="0"/>
                                                <Condition Binding="{Binding TodaySchedule.Count}" Value="0"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Upcoming Events -->
                <Border Style="{StaticResource CardStyle}" Width="380">
                    <StackPanel>
                        <TextBlock Text="UPCOMING EVENTS" Style="{StaticResource CardHeader}"/>
                        <ItemsControl ItemsSource="{Binding UpcomingDayEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" Padding="10,8" CornerRadius="8"
                                            Background="{StaticResource BgHover}"
                                            BorderBrush="{StaticResource BorderMedium}" BorderThickness="1"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="DayEventRow_MouseLeftButtonUp"
                                            Tag="{Binding SourceId}">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Edit" Click="DayEventEdit_Click"
                                                          Tag="{Binding SourceId}"/>
                                                <MenuItem Header="Delete" Click="DayEventDelete_Click"
                                                          Tag="{Binding SourceId}"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <DockPanel>
                                            <Path DockPanel.Dock="Left" Data="{StaticResource DayEventIconGeometry}"
                                                  Stroke="{StaticResource AccentAmber}" StrokeThickness="1.2"
                                                  Fill="{StaticResource AccentAmber}"
                                                  Width="9" Height="11" Stretch="Uniform"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding RelativeLabel}"
                                                       Foreground="{StaticResource AccentAmber}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No upcoming events"
                                   Visibility="{Binding UpcomingDayEvents.Count, Converter={StaticResource ZeroToVisibleConverter}, FallbackValue=Collapsed}"
                                   Foreground="{StaticResource TextMuted}" FontStyle="Italic" Margin="0,8"/>
                    </StackPanel>
                </Border>

                <!-- Weekly Hours -->
                <Border Style="{StaticResource CardStyle}" Width="380">
                    <StackPanel>
                        <TextBlock Text="THIS WEEK" Style="{StaticResource CardHeader}"/>
                        <TextBlock FontSize="42" FontWeight="Light" Foreground="{StaticResource AccentAmber}">
                            <Run Text="{Binding WeeklyHoursLogged, StringFormat='{}{0:0.00}'}"/>
                            <Run Text="h" FontSize="20" Foreground="{StaticResource TextMuted}"/>
                        </TextBlock>
                        <TextBlock Text="hours logged" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding WeeklyGroupSummaries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,4">
                                        <TextBlock Text="{Binding TotalHours, StringFormat='{}{0:0.00}h'}"
                                                   DockPanel.Dock="Right" Foreground="{StaticResource TextSecondary}"
                                                   Width="44" TextAlignment="Right"/>
                                        <Border Height="22" CornerRadius="6" Margin="0,0,10,0"
                                                Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}">
                                            <TextBlock Text="{Binding GroupName}" Foreground="White" FontSize="11"
                                                       FontWeight="Medium"
                                                       Margin="8,0" VerticalAlignment="Center"/>
                                        </Border>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Goals -->
                <Border Style="{StaticResource CardStyle}" Width="380">
                    <StackPanel>
                        <TextBlock Text="ACTIVE GOALS" Style="{StaticResource CardHeader}"/>
                        <ItemsControl ItemsSource="{Binding ActiveGoals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock Text="{Binding Label}" FontSize="12"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock DockPanel.Dock="Right" FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}">
                                                <Run Text="{Binding ActualHours, StringFormat='{}{0:0.00}'}"/>
                                                <Run Text="/" Foreground="{StaticResource TextMuted}"/>
                                                <Run Text="{Binding TargetHours, StringFormat='{}{0:0.00}h'}"/>
                                            </TextBlock>
                                        </DockPanel>
                                        <Border Height="6" CornerRadius="3"
                                                Background="{StaticResource BgSurface}" Margin="0,6,0,0">
                                            <Border Height="6" CornerRadius="3" HorizontalAlignment="Left"
                                                    Width="{Binding ProgressPercentage, Converter={StaticResource PercentToWidthConverter}, ConverterParameter=340}"
                                                    Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}"/>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No active goals — set them in Statistics"
                                   Visibility="{Binding ActiveGoals.Count, Converter={StaticResource ZeroToVisibleConverter}, FallbackValue=Collapsed}"
                                   Foreground="{StaticResource TextMuted}" FontStyle="Italic" Margin="0,8"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
