<UserControl x:Class="ActivityTracker.Views.DayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ActivityTracker.Views">
    <UserControl.Resources>
        <Geometry x:Key="DayEventIconGeometry">M 0,0 L 7,0 L 5,3 L 7,6 L 0,6 Z M 0,0 L 0,10</Geometry>
    </UserControl.Resources>
    <DockPanel>
        <TextBlock Text="{Binding DateHeader}" FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimary}" DockPanel.Dock="Top" Margin="0,0,0,10"
                   MouseRightButtonUp="DateHeader_MouseRightButtonUp">
            <TextBlock.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add whole-day event" Click="AddDayEvent_Click"/>
                </ContextMenu>
            </TextBlock.ContextMenu>
        </TextBlock>

        <!-- All-day row (pinned to header) -->
        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1" Padding="60,6,0,8" MinHeight="18">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add whole-day event" Click="AddDayEvent_Click"/>
                </ContextMenu>
            </Border.ContextMenu>
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="100"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding DayEvents}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,2" Padding="8,4" CornerRadius="4"
                                    Background="{StaticResource BgHover}"
                                    BorderBrush="{StaticResource BorderMedium}" BorderThickness="1"
                                    Tag="{Binding SourceId}">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Edit" Click="DayEventPill_Edit_Click"
                                                  Tag="{Binding SourceId}"/>
                                        <MenuItem Header="Delete" Click="DayEventPill_Delete_Click"
                                                  Tag="{Binding SourceId}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <DockPanel>
                                    <Path DockPanel.Dock="Left" Data="{StaticResource DayEventIconGeometry}"
                                          Stroke="{StaticResource AccentAmber}" StrokeThickness="1.2"
                                          Fill="{StaticResource AccentAmber}"
                                          Width="9" Height="11" Stretch="Uniform"
                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextPrimary}"
                                               FontSize="12" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Loaded="ScrollViewer_Loaded">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Time gutter -->
                <ItemsControl Grid.Column="0" ItemsSource="{x:Static views:DayView.Hours}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><Canvas Height="1440"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextMuted}" FontSize="10.5"
                                       Width="50" TextAlignment="Right" Margin="0,0,8,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Hour grid lines -->
                <ItemsControl Grid.Column="1" ItemsSource="{x:Static views:DayView.Hours}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><Canvas Height="1440"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                            <Setter Property="Canvas.Left" Value="0"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Line X1="0" X2="2000" Stroke="{StaticResource BorderSubtle}" StrokeThickness="1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Entry blocks -->
                <ItemsControl Grid.Column="1" ItemsSource="{Binding Entries}" x:Name="EntriesControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><Canvas Height="1440"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="4"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="6" Padding="10,6" Margin="0,0,16,0"
                                    MinWidth="200" Cursor="Hand"
                                    MouseLeftButtonDown="EntryBlock_MouseLeftButtonDown">
                                <Border.Background>
                                    <Binding Path="Color" Converter="{StaticResource StringToBrushConverter}"/>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="12">
                                        <Run Text="{Binding GroupName}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ActivityName}" Foreground="#FFFFFFDD" FontSize="11"/>
                                    <TextBlock Foreground="#FFFFFF99" FontSize="10">
                                        <Run Text="{Binding StartTime, StringFormat='{}{0:HH:mm}'}"/>
                                        <Run Text=" – "/>
                                        <Run Text="{Binding EndTime, StringFormat='{}{0:HH:mm}'}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Drag interaction layer -->
                <Canvas Grid.Column="1" Height="1440" Background="Transparent"
                        x:Name="DragCanvas"
                        MouseLeftButtonDown="DragCanvas_MouseLeftButtonDown"
                        MouseMove="DragCanvas_MouseMove"
                        MouseLeftButtonUp="DragCanvas_MouseLeftButtonUp"
                        Panel.ZIndex="-1">
                    <Canvas.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Add whole-day event" Click="AddDayEvent_Click"/>
                        </ContextMenu>
                    </Canvas.ContextMenu>
                    <Border x:Name="DragPreview" Visibility="Collapsed"
                            Background="#33F59E0B" BorderBrush="{StaticResource AccentAmber}"
                            BorderThickness="2" CornerRadius="6" IsHitTestVisible="False" MinWidth="100">
                        <TextBlock x:Name="DragPreviewText"
                                   Foreground="{StaticResource AccentAmber}" FontSize="11" FontWeight="SemiBold"
                                   Margin="8,4" VerticalAlignment="Top"/>
                    </Border>
                </Canvas>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</UserControl>
