<UserControl x:Class="ActivityTracker.Views.DayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ActivityTracker.Views">
    <DockPanel>
        <TextBlock Text="{Binding DateHeader}" FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimary}" DockPanel.Dock="Top" Margin="0,0,0,10"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Loaded="ScrollViewer_Loaded">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Time gutter -->
                <ItemsControl Grid.Column="0" ItemsSource="{x:Static views:DayView.Hours}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><Canvas Height="1440"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextMuted}" FontSize="10.5"
                                       Width="50" TextAlignment="Right" Margin="0,0,8,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Hour grid lines -->
                <ItemsControl Grid.Column="1" ItemsSource="{x:Static views:DayView.Hours}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><Canvas Height="1440"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                            <Setter Property="Canvas.Left" Value="0"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Line X1="0" X2="2000" Stroke="{StaticResource BorderSubtle}" StrokeThickness="1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Entry blocks -->
                <ItemsControl Grid.Column="1" ItemsSource="{Binding Entries}" x:Name="EntriesControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><Canvas Height="1440"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="4"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="6" Padding="10,6" Margin="0,0,16,0"
                                    MinWidth="200" Cursor="Hand"
                                    MouseLeftButtonDown="EntryBlock_MouseLeftButtonDown">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPlanned}" Value="True">
                                                <Setter Property="Opacity" Value="0.65"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="BorderBrush" Value="{Binding Color, Converter={StaticResource StringToBrushConverter}}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.Background>
                                    <Binding Path="Color" Converter="{StaticResource StringToBrushConverter}"/>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="12">
                                        <Run Text="{Binding GroupName}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ActivityName}" Foreground="#FFFFFFDD" FontSize="11"/>
                                    <TextBlock Foreground="#FFFFFF99" FontSize="10">
                                        <Run Text="{Binding StartTime, StringFormat='{}{0:HH:mm}'}"/>
                                        <Run Text=" – "/>
                                        <Run Text="{Binding EndTime, StringFormat='{}{0:HH:mm}'}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Drag interaction layer -->
                <Canvas Grid.Column="1" Height="1440" Background="Transparent"
                        x:Name="DragCanvas"
                        MouseLeftButtonDown="DragCanvas_MouseLeftButtonDown"
                        MouseMove="DragCanvas_MouseMove"
                        MouseLeftButtonUp="DragCanvas_MouseLeftButtonUp"
                        Panel.ZIndex="-1">
                    <Border x:Name="DragPreview" Visibility="Collapsed"
                            Background="#33F59E0B" BorderBrush="{StaticResource AccentAmber}"
                            BorderThickness="2" CornerRadius="6" IsHitTestVisible="False" MinWidth="100">
                        <TextBlock x:Name="DragPreviewText"
                                   Foreground="{StaticResource AccentAmber}" FontSize="11" FontWeight="SemiBold"
                                   Margin="8,4" VerticalAlignment="Top"/>
                    </Border>
                </Canvas>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</UserControl>
