<UserControl x:Class="ActivityTracker.Views.DayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ActivityTracker.Views">
    <DockPanel>
        <TextBlock Text="{Binding DateHeader}" FontSize="16" FontWeight="SemiBold"
                   Foreground="#333" DockPanel.Dock="Top" Margin="0,0,0,8"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Loaded="ScrollViewer_Loaded">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Time gutter -->
                <ItemsControl Grid.Column="0" ItemsSource="{x:Static views:DayView.Hours}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Height="1440"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" Foreground="#999" FontSize="11"
                                       Width="50" TextAlignment="Right" Margin="0,0,8,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Hour grid lines -->
                <ItemsControl Grid.Column="1" ItemsSource="{x:Static views:DayView.Hours}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Height="1440"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                            <Setter Property="Canvas.Left" Value="0"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Line X1="0" X2="2000" Stroke="#E8E8E8" StrokeThickness="1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Entry blocks -->
                <ItemsControl Grid.Column="1" ItemsSource="{Binding Entries}"
                              x:Name="EntriesControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Height="1440"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="4"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="8,4" Margin="0,0,12,0"
                                    MinWidth="200" Cursor="Hand"
                                    MouseLeftButtonDown="EntryBlock_MouseLeftButtonDown">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPlanned}" Value="True">
                                                <Setter Property="Opacity" Value="0.7"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="BorderBrush" Value="{Binding Color, Converter={StaticResource StringToBrushConverter}}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.Background>
                                    <Binding Path="Color" Converter="{StaticResource StringToBrushConverter}"/>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="12">
                                        <Run Text="{Binding GroupName}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ActivityName}" Foreground="White" FontSize="11"/>
                                    <TextBlock Foreground="#FFFFFFCC" FontSize="10">
                                        <Run Text="{Binding StartTime, StringFormat='{}{0:HH:mm}'}"/>
                                        <Run Text=" – "/>
                                        <Run Text="{Binding EndTime, StringFormat='{}{0:HH:mm}'}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Click handler for creating new entries -->
                <Canvas Grid.Column="1" Height="1440" Background="Transparent"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        Panel.ZIndex="-1"/>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</UserControl>
