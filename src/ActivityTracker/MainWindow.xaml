<Window x:Class="ActivityTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ActivityTracker.ViewModels"
        xmlns:views="clr-namespace:ActivityTracker.Views"
        Title="Activity Tracker"
        Height="850" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBase}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CalendarViewModel}">
            <views:CalendarView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ActivitiesViewModel}">
            <views:ActivitiesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StatisticsViewModel}">
            <views:StatisticsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ── -->
        <Border Grid.Column="0" Background="{StaticResource BgDeep}" Padding="0,20,0,20">
            <DockPanel>
                <!-- Logo area -->
                <StackPanel DockPanel.Dock="Top" Margin="24,0,24,32">
                    <TextBlock Text="A C T I V I T Y"
                               Foreground="{StaticResource AccentAmber}"
                               FontSize="10" FontWeight="Bold"
                               FontFamily="Segoe UI Variable, Segoe UI"/>
                    <TextBlock Text="Tracker"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="22" FontWeight="Light"
                               Margin="0,-2,0,0"
                               FontFamily="Segoe UI Variable, Segoe UI"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top">
                    <RadioButton x:Name="NavDashboard"
                                 Style="{StaticResource NavButtonStyle}"
                                 Content="Dashboard"
                                 IsChecked="True"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Dashboard"/>
                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Calendar"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Calendar"/>
                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Activities"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Activities"/>
                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Statistics"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Statistics"/>
                </StackPanel>

                <Border/> <!-- Spacer -->
            </DockPanel>
        </Border>

        <!-- Sidebar accent line -->
        <Border Grid.Column="0" HorizontalAlignment="Right" Width="1"
                Background="{StaticResource BorderSubtle}"/>

        <!-- ── Content Area ── -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="0"/>
    </Grid>
</Window>
