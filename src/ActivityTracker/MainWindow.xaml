<Window x:Class="ActivityTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ActivityTracker.ViewModels"
        xmlns:views="clr-namespace:ActivityTracker.Views"
        Title="Activity Tracker"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CalendarViewModel}">
            <views:CalendarView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ActivitiesViewModel}">
            <views:ActivitiesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StatisticsViewModel}">
            <views:StatisticsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#2D2D30" Padding="0,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Activity Tracker"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="20,8,20,24"/>

                <StackPanel DockPanel.Dock="Top">
                    <RadioButton x:Name="NavDashboard"
                                 Style="{StaticResource NavButtonStyle}"
                                 Content="&#xE80F;  Dashboard"
                                 IsChecked="True"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Dashboard"/>
                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="&#xE787;  Calendar"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Calendar"/>
                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="&#xE8D2;  Activities"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Activities"/>
                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="&#xE9D9;  Statistics"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Statistics"/>
                </StackPanel>

                <Border/> <!-- Spacer -->
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}"
                        Margin="0"/>
    </Grid>
</Window>
