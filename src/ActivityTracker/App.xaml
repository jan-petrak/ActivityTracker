<Application x:Class="ActivityTracker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ActivityTracker.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Midnight Studio · ordering matters: Palette defines the brushes
                 that every subsequent dictionary references via StaticResource. -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Palette.xaml"/>
                <ResourceDictionary Source="Themes/Typography.xaml"/>
                <ResourceDictionary Source="Themes/Buttons.xaml"/>
                <ResourceDictionary Source="Themes/Inputs.xaml"/>
                <ResourceDictionary Source="Themes/Containers.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Value converters -->
            <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
            <conv:StringMatchConverter x:Key="StringMatchConverter"/>
            <conv:NotNullToBoolConverter x:Key="NotNullToBoolConverter"/>
            <conv:NotNullToVisibleConverter x:Key="NotNullToVisibleConverter"/>
            <conv:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter"/>
            <conv:NonZeroToVisibleConverter x:Key="NonZeroToVisibleConverter"/>
            <conv:PercentToWidthConverter x:Key="PercentToWidthConverter"/>
            <conv:MinutesToBarHeightConverter x:Key="MinutesToBarHeightConverter"/>
            <conv:HoursToWidthConverter x:Key="HoursToWidthConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
